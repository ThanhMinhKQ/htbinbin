# Environment Variables for BBPMS

# REQUIRED - Database connection (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# REQUIRED - Secret key for sessions (generate a random string)
SECRET_KEY=your_secret_key_here

# Optional - Environment
ENVIRONMENT=production

# Optional - Log level
LOG_LEVEL=INFO

# OTA Features (disable on first deploy)
OTA_ENABLED=false

# Gmail OAuth2 (optional - for OTA email parsing)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=https://your-domain.com/api/ota/oauth/callback
GOOGLE_PUBSUB_TOPIC=
GMAIL_WATCH_EMAIL=

# Gemini API (optional - for AI features)
GEMINI_API_KEY=
